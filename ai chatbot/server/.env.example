# Copy this file to .env and fill in your real values. .env is gitignored - never commit it.

# Which provider to use: "gemini" (default) or "openai".
AI_PROVIDER=gemini

# Your API key. Leave blank to run in fallback mode (a few canned FAQ answers, no LLM).
AI_API_KEY=

# Model name. For gemini e.g. gemini-flash-latest ; for openai e.g. gpt-4o-mini
AI_MODEL=gemini-flash-latest

# Port the server listens on.
PORT=3000

# Comma-separated list of origins allowed to call the API (the dashboard's URL).
# Use * only for local testing - lock this down in production.
ALLOWED_ORIGINS=*
