# Copy this file to .env and fill in your real values. .env is gitignored - never commit it.

# Which provider to use: "openai" (default) or "gemini".
AI_PROVIDER=openai

# Your API key. Leave blank to run in heuristic fallback mode (no LLM, keyword-only feedback).
AI_API_KEY=

# Model name. For openai e.g. gpt-4o-mini ; for gemini e.g. gemini-1.5-flash
AI_MODEL=gpt-4o-mini

# Port the server listens on.
PORT=3000

# How many questions per practice session by default.
QUESTIONS_PER_SESSION=6

# Comma-separated list of origins allowed to call the API (the dashboard's URL).
# Use * only for local testing.
ALLOWED_ORIGINS=*
